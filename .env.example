# Convex
# Set by `npx convex dev` on first run; also available in the Convex dashboard.
NEXT_PUBLIC_CONVEX_URL=

# Clerk (auth)
# From your Clerk dashboard > API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk JWT issuer domain (Clerk dashboard > JWT Templates > Convex template).
# Also needs to be set on the Convex deployment itself — see convex/auth.config.ts.
CLERK_JWT_ISSUER_DOMAIN=

# Schematic (billing / feature flags)
NEXT_PUBLIC_SCHEMATIC_KEY=
NEXT_PUBLIC_SCHEMATIC_CUSTOMER_PORTAL_COMPONENT_ID=
SCHEMATIC_API_KEY=

# Inngest agent-kit models (inngest/agents/*.ts)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Inngest (only required when deploying to the Inngest cloud; local dev via
# `npx inngest-cli@latest dev` against http://localhost:3000/api/inngest
# doesn't need these)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Required for local dev with inngest v4 — without this, app/api/inngest/route.ts
# runs in "cloud mode" and rejects the local Inngest dev server's sync requests
# with 500s ("In cloud mode but no signing key found").
INNGEST_DEV=1
